        // Screenshot Capture
        async function captureScreenshots() {
            try {
                const response = await fetch('/api/capture_screenshot', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ batch_capture: true })
                });
                const result = await response.json();
                
                if (result.success) {
                    alert('Screenshot capture initiated for ' + result.queued + ' assets');
                    setTimeout(loadAssetData, 2000); // Refresh after 2 seconds
                } else {
                    alert('Error starting screenshot capture: ' + result.error);
                }
            } catch (error) {
                alert('Error starting screenshot capture: ' + error.message);
            }
        }

        // Export Functions
        function exportData(type) {
            let data, filename, headers;
            
            switch(type) {
                case 'assets':
                    data = assetsData;
                    filename = `assets_${new Date().getTime()}.csv`;
                    headers = ['Timestamp', 'Status', 'URL', 'Host', 'Title', 'Tech', 'Size', 'Method', 'Screenshot', 'New', 'Input'];
                    break;
                default:
                    alert('Export not yet implemented for ' + type);
                    return;
            }
            
            const csv = generateCSV(data, headers);
            downloadCSV(csv, filename);
        }

        function generateCSV(data, headers) {
            const rows = data.map(asset => [
                asset[assetMapping.timestamp] || '',
                asset[assetMapping.status] || '',
                asset[assetMapping.url] || '',
                asset[assetMapping.host] || '',
                asset[assetMapping.title] || '',
                Array.isArray(asset[assetMapping.tech_stack]) ? asset[assetMapping.tech_stack].join('; ') : (asset[assetMapping.tech_stack] || ''),
                asset[assetMapping.size] || '',
                asset[assetMapping.method] || asset.tool || '',
                asset[assetMapping.screenshot] ? 'YES' : 'NO',
                asset.newly_discovered ? 'YES' : 'NO',
                asset[assetMapping.source] || ''
            ]);
            
            return [headers, ...rows].map(row => 
                row.map(field => `"${String(field).replace(/"/g, '""')}"`).join(',')
            ).join('\n');
        }

        function downloadCSV(csv, filename) {
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.setAttribute('hidden', '');
            a.setAttribute('href', url);
            a.setAttribute('download', filename);
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        // Placeholder functions for missing views (to be implemented)
        async function loadVulnerabilityData() {
    try {
        const response = await fetch('/api/vulns');
        const data = await response.json();

        const container = document.getElementById('vulnerabilities-table');
        if (!container) return;

        if (data.error) {
            container.innerHTML = '<div class="alert alert-error">Error loading vulnerability data: ' + data.error + '</div>';
            return;
        }

        if (data.vulnerabilities && data.vulnerabilities.length > 0) {
            // Format the vulnerability data into a table
            let tableHTML = `
                <table class="siem-table">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>Type</th>
                            <th>Target URL</th>
                            <th>Severity</th>
                            <th>Confidence</th>
                            <th>Description</th>
                            <th>Payload</th>
                            <th>Evidence</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.vulnerabilities.forEach(vuln => {
                // Use global config for vulnerability mappings
                const vulnMapping = globalConfig.vulnerability_mappings || {};
                const vulnDisplay = globalConfig.vulnerability_display || {};
                
                const safeDescription = escapeHtml(vuln[vulnMapping.description] || vuln.description || 'No description available');
                const safeUrl = vuln[vulnMapping.asset_url] || vuln.asset_url || 'Unknown';
                const safeType = vuln[vulnMapping.vuln_type] || vuln.type || 'Unknown';
                const safeTimestamp = vuln[vulnMapping.discovered_at] || vuln.detected_at || 'Unknown';
                const safePayload = escapeHtml(vuln[vulnMapping.payload] || vuln.payload || 'No payload captured');
                const safeEvidence = escapeHtml(vuln[vulnMapping.evidence] || vuln.evidence || 'No evidence captured');
                const confidence = vuln[vulnMapping.confidence] || vuln.confidence || 0.5;
                const severity = vuln[vulnMapping.severity] || vuln.severity || 'MEDIUM';
                const severityClass = severity.toLowerCase();
                
                // Get display config
                const typeConfig = vulnDisplay.type_display?.[safeType] || {};
                const severityColor = vulnDisplay.severity_colors?.[severity] || '#6b7280';
                const severityIcon = vulnDisplay.severity_icons?.[severity] || '⚡';
                const typeIcon = typeConfig.icon || '🔍';
                const typeLabel = typeConfig.label || safeType;
                
                tableHTML += `
                    <tr>
                        <td>${formatTimestamp(safeTimestamp)}</td>
                        <td>
                            <span style="color: ${typeConfig.color || '#ef4444'};">
                                ${typeIcon} ${typeLabel}
                            </span>
                        </td>
                        <td>
                            <a href="${escapeHtml(safeUrl)}" target="_blank" class="asset-url">
                                ${truncate(safeUrl, 40)}
                            </a>
                        </td>
                        <td>
                            <span style="color: ${severityColor}; font-weight: bold;">
                                ${severityIcon} ${severity}
                            </span>
                        </td>
                        <td>
                            <span style="color: ${confidence >= 0.8 ? '#10b981' : confidence >= 0.6 ? '#f59e0b' : '#ef4444'}; font-weight: bold;">
                                ${Math.round(confidence * 100)}%
                            </span>
                        </td>
                        <td>
                            <span title="${escapeHtml(safeDescription)}" onclick="showVulnDetails('${escapeHtml(safeDescription)}', '${safeType} Description')" 
                                  style="cursor: pointer; color: #60a5fa; text-decoration: underline;">
                                ${truncate(safeDescription, 50)}
                            </span>
                        </td>
                        <td>
                            <span title="${escapeHtml(safePayload)}" onclick="showVulnDetails('${escapeHtml(safePayload)}', 'Exploit Payload')" 
                                  style="cursor: pointer; color: #f97316; text-decoration: underline; font-family: monospace;">
                                ${truncate(safePayload, 30)}
                            </span>
                        </td>
                        <td>
                            <span title="${escapeHtml(safeEvidence)}" onclick="showVulnDetails('${escapeHtml(safeEvidence)}', 'Evidence')" 
                                  style="cursor: pointer; color: #fbbf24; text-decoration: underline;">
                                ${truncate(safeEvidence, 40)}
                            </span>
                        </td>
                    </tr>
                `;
            });

            tableHTML += `
                    </tbody>
                </table>
            `;

            container.innerHTML = tableHTML;
        } else {
            container.innerHTML = '<div class="alert alert-warning">No vulnerabilities found</div>';
        }
    } catch (error) {
        console.error('Error loading vulnerability data:', error);
        container.innerHTML = '<div class="alert alert-error">Network error loading vulnerability data</div>';
    }
}

        async function loadMLXSSData() {
    try {
        const response = await fetch('/api/ml_xss_results');
        const data = await response.json();

        const container = document.getElementById('ml-results-table');
        if (!container) return;

        if (data.error) {
            container.innerHTML = '<div class="alert alert-error">Error loading ML XSS data: ' + data.error + '</div>';
            return;
        }

        if (data.results && data.results.length > 0) {
            // Format the ML XSS data into a table
            let tableHTML = `
                <table class="siem-table">
                    <thead>
                        <tr>
                            <th>URL</th>
                            <th>Parameter</th>
                            <th>Payload</th>
                            <th>ML Score</th>
                            <th>Confidence</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            data.results.forEach(result => {
                // Safely escape XSS payloads to prevent execution
                const safePayload = escapeHtml(result.payload || '');
                const safeUrl = escapeHtml(result.url || '');
                const safeParameter = escapeHtml(result.parameter || '');
                
                tableHTML += `
                    <tr>
                        <td>${safeUrl}</td>
                        <td>${safeParameter}</td>
                        <td><code style="color: #ff6b6b; background: #2d2d2d; padding: 2px 4px; border-radius: 2px;">${safePayload}</code></td>
                        <td>${result.ml_score}</td>
                        <td>${result.confidence}</td>
                        <td>${result.timestamp}</td>
                    </tr>
                `;
            });

            tableHTML += `
                    </tbody>
                </table>
            `;

            container.innerHTML = tableHTML;
        } else {
            container.innerHTML = '<div class="alert alert-warning">No ML XSS results found</div>';
        }
    } catch (error) {
        console.error('Error loading ML XSS data:', error);
        container.innerHTML = '<div class="alert alert-error">Network error loading ML XSS data</div>';
    }
}

