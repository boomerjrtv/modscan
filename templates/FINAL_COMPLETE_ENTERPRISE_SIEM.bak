        // Utility Functions
        function updateElementText(id, text) {
            const element = document.getElementById(id);
            if (element) element.textContent = text;
        }

        function formatTimestamp(timestamp) {
            if (!timestamp) return '-';
            const date = new Date(timestamp);
            return date.toLocaleString('en-US', {
                month: '2-digit',
                day: '2-digit', 
                year: '2-digit',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: false
            }).replace(',', '');
        }

        function getStatusClass(status) {
            if (!status) return 'status-default';
            if (status === 200) return 'status-200';
            if ([301, 302, 307, 308].includes(status)) return 'status-301';
            if (status === 403) return 'status-403';
            if (status === 404) return 'status-404';
            if ([500, 502, 503].includes(status)) return 'status-500';
            return 'status-default';
        }

        function formatBytes(bytes) {
            if (!bytes) return '0B';
            const sizes = ['B', 'KB', 'MB', 'GB'];
            if (bytes === 0) return '0B';
            const i = Math.floor(Math.log(bytes) / Math.log(1024));
            return Math.round(bytes / Math.pow(1024, i) * 100) / 100 + sizes[i];
        }

        function truncate(str, length) {
            if (!str) return '';
            return str.length > length ? str.substring(0, length) + '...' : str;
        }


        function escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;")
                .replace(/\//g, "&#x2F;");
        }

        function showError(containerId, message, colspan) {
            const container = document.getElementById(containerId);
            if (container) {
                container.innerHTML = `
                    <tr>
                        <td colspan="${colspan}" style="padding: 20px; text-align: center; color: #ef4444;">
                            ERROR: ${message}
                        </td>
                    </tr>
                `;
            }
        }

        // ==================== LIVE NOTIFICATION SYSTEM ====================
        let lastNotificationCheck = Date.now();
        let shownNotifications = new Set();

        function checkForNotifications() {
            fetch('/api/notifications')
                .then(response => response.json())
                .then(notifications => {
                    notifications.forEach(notification => {
                        if (!shownNotifications.has(notification.id)) {
                            showNotification(notification);
                            shownNotifications.add(notification.id);
                        }
                    });
                })
                .catch(error => {
                    console.error('Error fetching notifications:', error);
                });
        }

        function showVulnDetails(content, title) {
            // Create modal if it doesn't exist
            if (!document.getElementById('vuln-details-modal')) {
                const modalHTML = `
                    <div id="vuln-details-modal" class="modal-overlay" style="display: none;">
                        <div class="modal-content" style="max-width: 600px;">
                            <div class="modal-header">
                                <h3 id="vuln-details-title">Vulnerability Details</h3>
                                <button class="modal-close" onclick="closeVulnDetailsModal()">&times;</button>
                            </div>
                            <div class="modal-body">
                                <pre id="vuln-details-content" style="white-space: pre-wrap; word-wrap: break-word; background: #f8f9fa; padding: 15px; border-radius: 4px; max-height: 400px; overflow-y: auto;"></pre>
                            </div>
                        </div>
                    </div>
                `;
                document.body.insertAdjacentHTML('beforeend', modalHTML);
            }
            
            // Update modal content
            document.getElementById('vuln-details-title').textContent = title || 'Details';
            document.getElementById('vuln-details-content').textContent = content || 'No details available';
            document.getElementById('vuln-details-modal').style.display = 'flex';
        }
        
        function closeVulnDetailsModal() {
            const modal = document.getElementById('vuln-details-modal');
            if (modal) {
                modal.style.display = 'none';
            }
        }

        function showNotification(notification) {
            const container = document.getElementById('notification-container');
            
            // Create notification element
            const notificationElement = document.createElement('div');
            notificationElement.className = `notification-popup ${notification.type || 'discovery'}`;
            notificationElement.id = `notification-${notification.id}`;
            
            notificationElement.innerHTML = `
                <button class="notification-close" onclick="closeNotification('${notification.id}')">&times;</button>
                <div class="notification-header">${getNotificationIcon(notification.type)} ${notification.message}</div>
                ${notification.details ? `<div class="notification-details">${notification.details}</div>` : ''}
            `;
            
            // Add to container
            container.appendChild(notificationElement);
            
            // Show with animation
            setTimeout(() => {
                notificationElement.classList.add('show');
            }, 100);
        }
        
        function closeNotification(notificationId) {
            const notification = document.getElementById(`notification-${notificationId}`);
            if (notification) {
                notification.classList.remove('show');
                setTimeout(() => {
                    notification.remove();
                }, 300);
            }
        }

        function getNotificationIcon(type) {
            switch(type) {
                case 'discovery': return '🔍';
                case 'vulnerability': return '🚨';
                case 'error': return '❌';
                case 'warning': return '⚠️';
                default: return '📊';
            }
        }
        
        // Response modal functionality - make it globally accessible
        window.showAssetResponse = function(element) {
            const responseBody = element.getAttribute('data-response');
            const url = element.getAttribute('data-url');
            
            // Create modal if it doesn't exist
            let modal = document.getElementById('response-modal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'response-modal';
                modal.className = 'modal';
                modal.style.cssText = 'display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.8);';
                modal.innerHTML = `
                    <div class="modal-content" style="position: relative; background: #2a2a2a; margin: 2% auto; padding: 0; border: 1px solid #555; border-radius: 8px; width: 90%; height: 90%; max-width: 1200px;">
                        <div style="background: #1a1a1a; padding: 20px; border-radius: 8px 8px 0 0; border-bottom: 1px solid #555;">
                            <span class="close" onclick="closeResponseModal()" style="color: #fff; float: right; font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
                            <h3 id="response-modal-title" style="color: #fff; margin: 0; font-family: Arial, sans-serif;">Response Body</h3>
                        </div>
                        <div style="background: #1a1a1a; padding: 20px; max-height: 80vh; overflow: auto;">
                            <pre id="response-content" style="color: #00ff00; font-family: 'Courier New', monospace; font-size: 11px; white-space: pre-wrap; word-wrap: break-word; margin: 0; line-height: 1.4;"></pre>
                        </div>
                    </div>
                `;
                document.body.appendChild(modal);
            }

            const modalTitle = document.getElementById('response-modal-title');
            const responseContent = document.getElementById('response-content');
            
            modalTitle.textContent = `Response: ${truncate(url, 80)}`;
            responseContent.textContent = responseBody || 'No response captured';
            
            modal.style.display = 'block';
        };
        
        window.closeResponseModal = function() {
            const modal = document.getElementById('response-modal');
            if (modal) modal.style.display = 'none';
        };

        // Asset reconnaissance details modal
        window.showAssetDetails = function(assetId) {
            // Find asset in current asset data
            const asset = currentAssetData.find(a => a[assetMapping.id] == assetId);
            if (!asset) return;
            
            const url = asset[assetMapping.url];
            const takeoverRisk = asset[assetMapping.takeover_risk] || 'SAFE';
            const discoveredParams = JSON.parse(asset[assetMapping.discovered_params] || '[]');
            const apiEndpoints = JSON.parse(asset[assetMapping.api_endpoints] || '[]');
            const securityHeaders = JSON.parse(asset[assetMapping.security_headers] || '{}');
            const techVersions = JSON.parse(asset[assetMapping.tech_versions] || '{}');
            const dnsRecords = JSON.parse(asset[assetMapping.dns_records] || '{}');
            const asnInfo = JSON.parse(asset[assetMapping.asn_info] || '{}');
            
            let modal = document.getElementById('asset-details-modal');
            if (!modal) {
                modal = document.createElement('div');
                modal.id = 'asset-details-modal';
                modal.className = 'modal';
                modal.style.cssText = 'display: none; position: fixed; z-index: 9999; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.8);';
                modal.innerHTML = `
                    <div class="modal-content" style="position: relative; background: #2a2a2a; margin: 2% auto; padding: 0; border: 1px solid #555; border-radius: 8px; width: 95%; height: 90%; max-width: 1400px;">
                        <div style="background: #1a1a1a; padding: 20px; border-radius: 8px 8px 0 0; border-bottom: 1px solid #555;">
                            <span class="close" onclick="closeAssetDetailsModal()" style="color: #fff; float: right; font-size: 28px; font-weight: bold; cursor: pointer;">&times;</span>
                            <h3 id="asset-details-title" style="color: #fff; margin: 0; font-family: Arial, sans-serif;">🔍 Asset Reconnaissance Details</h3>
                        </div>
                        <div style="background: #1a1a1a; padding: 20px; max-height: 80vh; overflow: auto;">
                            <div id="asset-details-content" style="color: #e0e0e0; font-family: 'Courier New', monospace; font-size: 12px;"></div>
                        </div>
                    </div>
                `;
                document.body.appendChild(modal);
            }

            const modalTitle = document.getElementById('asset-details-title');
            const detailsContent = document.getElementById('asset-details-content');
            
            modalTitle.innerHTML = `🔍 Reconnaissance: ${truncate(url, 60)}`;
            
            let content = `<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">`;
            
            // Left column
            content += `<div>`;
            
            // Subdomain Takeover Risk
            const riskColor = takeoverRisk === 'HIGH' ? '#dc2626' : takeoverRisk === 'MEDIUM' ? '#ca8a04' : '#16a34a';
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px; border-left: 4px solid ${riskColor};">
                    <h4 style="color: #fff; margin-bottom: 10px;">🎯 Subdomain Takeover Risk</h4>
                    <div style="color: ${riskColor}; font-weight: bold;">${takeoverRisk}</div>
                </div>
            `;
            
            // Discovered Parameters
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px;">
                    <h4 style="color: #fff; margin-bottom: 10px;">📋 Discovered Parameters (${discoveredParams.length})</h4>
                    <div style="max-height: 200px; overflow-y: auto;">`;
            if (discoveredParams.length > 0) {
                discoveredParams.forEach(param => {
                    content += `<div style="color: #4ade80; margin: 4px 0;">${param}</div>`;
                });
            } else {
                content += `<div style="color: #666;">No parameters discovered</div>`;
            }
            content += `</div></div>`;
            
            // Technology Versions
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px;">
                    <h4 style="color: #fff; margin-bottom: 10px;">⚙️ Technology Versions</h4>
                    <div style="max-height: 200px; overflow-y: auto;">`;
            if (Object.keys(techVersions).length > 0) {
                Object.entries(techVersions).forEach(([tech, version]) => {
                    content += `<div style="color: #fbbf24; margin: 4px 0;"><strong>${tech}:</strong> ${version}</div>`;
                });
            } else {
                content += `<div style="color: #666;">No version information available</div>`;
            }
            content += `</div></div>`;
            
            content += `</div>`; // Close left column
            
            // Right column
            content += `<div>`;
            
            // API Endpoints
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px;">
                    <h4 style="color: #fff; margin-bottom: 10px;">🌐 Discovered APIs (${apiEndpoints.length})</h4>
                    <div style="max-height: 200px; overflow-y: auto;">`;
            if (apiEndpoints.length > 0) {
                apiEndpoints.forEach(api => {
                    content += `<div style="color: #0ea5e9; margin: 4px 0;">${api}</div>`;
                });
            } else {
                content += `<div style="color: #666;">No API endpoints discovered</div>`;
            }
            content += `</div></div>`;
            
            // Security Headers
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px;">
                    <h4 style="color: #fff; margin-bottom: 10px;">🔒 Security Headers</h4>
                    <div style="max-height: 200px; overflow-y: auto;">`;
            if (Object.keys(securityHeaders).length > 0) {
                Object.entries(securityHeaders).forEach(([header, value]) => {
                    const isSecure = ['strict-transport-security', 'content-security-policy', 'x-frame-options'].includes(header.toLowerCase());
                    const color = isSecure ? '#16a34a' : '#ca8a04';
                    content += `<div style="color: ${color}; margin: 4px 0;"><strong>${header}:</strong> ${truncate(value, 50)}</div>`;
                });
            } else {
                content += `<div style="color: #666;">No security headers analyzed</div>`;
            }
            content += `</div></div>`;
            
            // DNS Records
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px;">
                    <h4 style="color: #fff; margin-bottom: 10px;">🔍 DNS Records</h4>
                    <div style="max-height: 200px; overflow-y: auto;">`;
            if (Object.keys(dnsRecords).length > 0) {
                Object.entries(dnsRecords).forEach(([type, records]) => {
                    if (Array.isArray(records) && records.length > 0) {
                        content += `<div style="color: #a855f7; margin: 8px 0;"><strong>${type}:</strong></div>`;
                        records.forEach(record => {
                            content += `<div style="color: #d1d5db; margin-left: 15px; margin: 2px 0;">${record}</div>`;
                        });
                    }
                });
            } else {
                content += `<div style="color: #666;">No DNS records available</div>`;
            }
            content += `</div></div>`;
            
            // ASN Information (already defined above)
            content += `
                <div style="margin-bottom: 20px; padding: 15px; background: #333; border-radius: 6px;">
                    <h4 style="color: #fff; margin-bottom: 10px;">🌐 ASN Information</h4>
                    <div style="max-height: 200px; overflow-y: auto;">`;
            if (Object.keys(asnInfo).length > 0) {
                content += `<div style="color: #22c55e; margin: 4px 0;"><strong>IP:</strong> ${asnInfo.ip || 'Unknown'}</div>`;
                content += `<div style="color: #3b82f6; margin: 4px 0;"><strong>ASN:</strong> AS${asnInfo.asn_number || 'Unknown'}</div>`;
                content += `<div style="color: #f59e0b; margin: 4px 0;"><strong>Organization:</strong> ${asnInfo.asn_org || 'Unknown'}</div>`;
                content += `<div style="color: #8b5cf6; margin: 4px 0;"><strong>Country:</strong> ${asnInfo.country || 'Unknown'}</div>`;
                if (asnInfo.cloud_provider) {
                    content += `<div style="color: #ec4899; margin: 4px 0;"><strong>Cloud Provider:</strong> ${asnInfo.cloud_provider}</div>`;
                }
                if (asnInfo.ports_open && asnInfo.ports_open.length > 0) {
                    content += `<div style="color: #ef4444; margin: 4px 0;"><strong>Open Ports:</strong> ${asnInfo.ports_open.join(', ')}</div>`;
                }
            } else {
                content += `<div style="color: #666;">ASN information not collected yet</div>`;
            }
            content += `</div></div>`;
            
            content += `</div>`; // Close right column
            content += `</div>`; // Close grid
            
            detailsContent.innerHTML = content;
            modal.style.display = 'block';
        };
        
        window.closeAssetDetailsModal = function() {
            const modal = document.getElementById('asset-details-modal');
            if (modal) modal.style.display = 'none';
        };
    </script>
</body>
</html>
